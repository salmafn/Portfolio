---
/**
 * @component Skills
 * @description Skills section with two sub-sections: Technical Skills
 * (grid of cards with icon, category title, skill chips, and count)
 * and Soft Skills (optional horizontal grid with icon and description).
 */

import { technicalSkills, softSkills } from '../data/portfolio';

/* Lucide SVG paths */
const icons: Record<string, string> = {
  brain: '<path d="M9.5 2A5.5 5.5 0 0 0 5 5.5C5 7.9 6.7 9.8 9 10.3V14h6v-3.7c2.3-.5 4-2.4 4-4.8A5.5 5.5 0 0 0 14.5 2h-5z"/><path d="M12 10v12"/>',
  code: '<polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>',
  database: '<ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M21 12c0 1.66-4 3-9 3s-9-1.34-9-3"/><path d="M3 5v14c0 1.66 4 3 9 3s9-1.34 9-3V5"/>',
  'bar-chart': '<line x1="12" y1="20" x2="12" y2="10"/><line x1="18" y1="20" x2="18" y2="4"/><line x1="6" y1="20" x2="6" y2="16"/>',
  globe: '<circle cx="12" cy="12" r="10"/><line x1="2" y1="12" x2="22" y2="12"/><path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>',
  cpu: '<rect x="4" y="4" width="16" height="16" rx="2" ry="2"/><rect x="9" y="9" width="6" height="6"/><line x1="9" y1="1" x2="9" y2="4"/><line x1="15" y1="1" x2="15" y2="4"/><line x1="9" y1="20" x2="9" y2="23"/><line x1="15" y1="20" x2="15" y2="23"/><line x1="20" y1="9" x2="23" y2="9"/><line x1="20" y1="14" x2="23" y2="14"/><line x1="1" y1="9" x2="4" y2="9"/><line x1="1" y1="14" x2="4" y2="14"/>',
  'git-branch': '<line x1="6" y1="3" x2="6" y2="15"/><circle cx="18" cy="6" r="3"/><circle cx="6" cy="18" r="3"/><path d="M18 9a9 9 0 0 1-9 9"/>',
  lightbulb: '<path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/>',
  target: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
  clock: '<circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/>',
  layers: '<polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/>',
  'refresh-cw': '<polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/>',
  users: '<path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
  zap: '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
};
---

<section class="section skills" id="skills">
  <div class="container">
    <div class="section__header reveal">
      <span class="section__label">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <Fragment set:html={icons.zap} />
        </svg>
        Compétences
      </span>
      <h2 class="section__title">Mon <span class="gradient-text">Arsenal</span> Technique</h2>
    </div>

    <!-- Technical Skills -->
    <div class="divider-label reveal">
      <span>Technical Skills</span>
    </div>

    <div class="skills__grid stagger-children">
      {technicalSkills.map((category, i) => (
        <div class="skills__card glass-card reveal" style={`--stagger-index: ${i}`}>
          <div class="skills__card-header">
            <div class="skills__icon-box">
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={icons[category.icon] || ''} />
              </svg>
            </div>
            <div>
              <h3 class="skills__card-title">{category.title}</h3>
              <span class="skills__card-count">{category.skills.length} compétences</span>
            </div>
          </div>
          <div class="skills__chips">
            {category.skills.map((skill) => (
              <span class="skills__chip">{skill}</span>
            ))}
          </div>
          <div class="skills__card-glow"></div>
        </div>
      ))}
    </div>

    <!-- Soft Skills -->
    {softSkills.length > 0 && (
      <>
        <div class="divider-label reveal">
          <span>Soft Skills</span>
        </div>

        <div class="skills__soft-grid stagger-children">
          {softSkills.map((skill, i) => (
            <div class="skills__soft-card glass-card reveal" style={`--stagger-index: ${i}`}>
              <div class="skills__soft-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <Fragment set:html={icons[skill.icon] || ''} />
                </svg>
              </div>
              <div>
                <h4 class="skills__soft-name">{skill.name}</h4>
                <p class="skills__soft-desc">{skill.description}</p>
              </div>
            </div>
          ))}
        </div>
      </>
    )}
  </div>
</section>

<style>
  /* ================================================================== */
  /*  Technical Skills Grid                                              */
  /* ================================================================== */

  .skills__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 1.5rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .skills__card {
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .skills__card-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--gradient-primary);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .skills__card:hover .skills__card-glow {
    opacity: 1;
  }

  .skills__card-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 1.25rem;
  }

  .skills__icon-box {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.15);
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
  }

  .skills__icon-box svg {
    width: 22px;
    height: 22px;
    color: var(--color-primary-light);
  }

  .skills__card:hover .skills__icon-box {
    transform: scale(1.1);
    background: rgba(99, 102, 241, 0.15);
    box-shadow: 0 0 16px rgba(99, 102, 241, 0.2);
  }

  .skills__card-title {
    font-size: 1rem;
    font-weight: 700;
    color: #fff;
  }

  .skills__card-count {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-muted);
  }

  .skills__chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .skills__chip {
    padding: 0.3rem 0.7rem;
    background: rgba(99, 102, 241, 0.06);
    border: 1px solid rgba(99, 102, 241, 0.12);
    border-radius: var(--radius-full);
    font-size: 0.75rem;
    font-weight: 500;
    color: var(--color-text-muted);
    transition: all var(--transition-fast);
  }

  .skills__chip:hover {
    background: rgba(99, 102, 241, 0.12);
    color: var(--color-primary-light);
    border-color: rgba(99, 102, 241, 0.25);
  }

  /* ================================================================== */
  /*  Soft Skills Grid                                                   */
  /* ================================================================== */

  .skills__soft-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1rem;
    max-width: 1000px;
    margin: 0 auto;
  }

  .skills__soft-card {
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    padding: 1.25rem;
  }

  .skills__soft-icon {
    flex-shrink: 0;
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(168, 85, 247, 0.08);
    border: 1px solid rgba(168, 85, 247, 0.15);
    border-radius: var(--radius-md);
    transition: all var(--transition-base);
  }

  .skills__soft-icon svg {
    width: 20px;
    height: 20px;
    color: var(--color-accent-light);
  }

  .skills__soft-card:hover .skills__soft-icon {
    transform: scale(1.1);
    background: rgba(168, 85, 247, 0.15);
    box-shadow: 0 0 16px rgba(168, 85, 247, 0.2);
  }

  .skills__soft-name {
    font-size: 0.95rem;
    font-weight: 600;
    color: #fff;
    margin-bottom: 0.25rem;
  }

  .skills__soft-desc {
    font-size: 0.82rem;
    color: var(--color-text-muted);
    line-height: 1.5;
  }

  @media (max-width: 768px) {
    .skills__grid {
      grid-template-columns: 1fr;
    }

    .skills__soft-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
