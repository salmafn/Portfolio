---
/**
 * @component Education
 * @description Vertical timeline with gradient dots and connecting line.
 * Each entry has period badge, degree, field, institution link,
 * and description. "Latest" badge on the first entry.
 */

import { education } from '../data/portfolio';

const externalLinkIcon = '<line x1="18" y1="13" x2="18" y2="6"/><polyline points="15 6 18 6 18 9"/><path d="M10 14 18 6"/><path d="M21 14v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>';
---

<section class="section education" id="education">
  <div class="container">
    <div class="section__header reveal">
      <span class="section__label">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="M22 10v6M2 10l10-5 10 5-10 5z"/><path d="M6 12v5c0 2 6 3 6 3s6-1 6-3v-5"/>
        </svg>
        Formation
      </span>
      <h2 class="section__title">Parcours <span class="gradient-text">Académique</span></h2>
    </div>

    <div class="education__timeline stagger-children">
      <div class="education__line" aria-hidden="true"></div>

      {education.map((entry, i) => (
        <div class="education__entry reveal" style={`--stagger-index: ${i}`}>
          <div class="education__dot" aria-hidden="true">
            <div class="education__dot-inner"></div>
          </div>

          <div class="education__card glass-card">
            <div class="education__card-top">
              <span class="education__period">{entry.period}</span>
              {entry.isLatest && <span class="education__badge-latest">Latest</span>}
            </div>

            <h3 class="education__degree">{entry.degree}</h3>
            <p class="education__field">{entry.field}</p>

            {entry.institutionUrl ? (
              <a href={entry.institutionUrl} target="_blank" rel="noopener noreferrer" class="education__institution">
                {entry.institution}
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="education__ext-icon">
                  <Fragment set:html={externalLinkIcon} />
                </svg>
              </a>
            ) : (
              <p class="education__institution education__institution--text">{entry.institution}</p>
            )}

            <p class="education__description">{entry.description}</p>

            <div class="education__card-glow"></div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .education__timeline {
    position: relative;
    max-width: 700px;
    margin: 0 auto;
    padding-left: 2.5rem;
  }

  .education__line {
    position: absolute;
    left: 11px;
    top: 0;
    bottom: 0;
    width: 2px;
    background: linear-gradient(to bottom, var(--color-primary), var(--color-accent), transparent);
  }

  .education__entry {
    position: relative;
    margin-bottom: 2rem;
  }

  .education__entry:last-child {
    margin-bottom: 0;
  }

  /* Dot */
  .education__dot {
    position: absolute;
    left: -2.5rem;
    top: 1.5rem;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: var(--gradient-primary);
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 0 12px rgba(99, 102, 241, 0.3);
    animation: dot-glow 3s ease-in-out infinite;
  }

  .education__dot-inner {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: var(--color-bg);
  }

  @keyframes dot-glow {
    0%, 100% { box-shadow: 0 0 8px rgba(99, 102, 241, 0.2); }
    50% { box-shadow: 0 0 20px rgba(99, 102, 241, 0.4); }
  }

  /* Card */
  .education__card {
    padding: 1.5rem;
    position: relative;
    overflow: hidden;
  }

  .education__card-glow {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: var(--gradient-primary);
    opacity: 0;
    transition: opacity var(--transition-base);
  }

  .education__card:hover .education__card-glow {
    opacity: 1;
  }

  .education__card-top {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.75rem;
    flex-wrap: wrap;
  }

  .education__period {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--color-text-muted);
    padding: 0.25rem 0.75rem;
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.12);
    border-radius: var(--radius-full);
  }

  .education__badge-latest {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    font-weight: 700;
    color: var(--color-success);
    padding: 0.2rem 0.6rem;
    background: rgba(34, 197, 94, 0.1);
    border: 1px solid rgba(34, 197, 94, 0.2);
    border-radius: var(--radius-full);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .education__degree {
    font-size: 1.1rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 0.25rem;
  }

  .education__field {
    font-size: 0.9rem;
    font-weight: 500;
    color: var(--color-primary-light);
    margin-bottom: 0.5rem;
  }

  .education__institution {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: var(--color-text-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
    margin-bottom: 0.75rem;
  }

  a.education__institution:hover {
    color: var(--color-primary-light);
  }

  .education__institution--text {
    display: block;
    margin-bottom: 0.75rem;
  }

  .education__ext-icon {
    width: 14px;
    height: 14px;
    opacity: 0.6;
  }

  .education__description {
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  @media (max-width: 768px) {
    .education__timeline {
      padding-left: 0;
    }

    .education__line {
      display: none;
    }

    .education__dot {
      display: none;
    }

    .education__card {
      padding: 1.25rem;
    }
  }
</style>
