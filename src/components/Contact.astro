---
/**
 * @component Contact
 * @description Two-column grid with info cards (email, phone, location)
 * and a functional contact form using formsubmit.co.
 * Social links displayed as square icons with hover effects.
 */

import { personalInfo, socialLinks } from '../data/portfolio';

/* Lucide SVG paths */
const icons: Record<string, string> = {
  mail: '<path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/>',
  phone: '<path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>',
  'map-pin': '<path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/>',
  send: '<line x1="22" y1="2" x2="11" y2="13"/><polygon points="22 2 15 22 11 13 2 9 22 2"/>',
  linkedin: '<path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/><rect x="2" y="9" width="4" height="12"/><circle cx="4" cy="4" r="2"/>',
  github: '<path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>',
};

const contactCards = [
  { icon: 'mail', label: 'Email', value: personalInfo.emails[0], href: `mailto:${personalInfo.emails[0]}` },
  ...(personalInfo.phone ? [{ icon: 'phone', label: 'Téléphone', value: personalInfo.phone, href: `tel:${personalInfo.phone.replace(/\s/g, '')}` }] : []),
  { icon: 'map-pin', label: 'Localisation', value: personalInfo.location },
];

const formAction = `https://formsubmit.co/${personalInfo.emails[0]}`;
---

<section class="section contact" id="contact">
  <div class="container">
    <div class="section__header reveal">
      <span class="section__label">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <Fragment set:html={icons.mail} />
        </svg>
        Contact
      </span>
      <h2 class="section__title">Me <span class="gradient-text">Contacter</span></h2>
    </div>

    <div class="contact__grid">
      <!-- Info column -->
      <div class="contact__info reveal">
        <div class="contact__cards">
          {contactCards.map((card) => (
            <div class="contact__card glass-card">
              <div class="contact__card-icon">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <Fragment set:html={icons[card.icon] || ''} />
                </svg>
              </div>
              <div>
                <span class="contact__card-label">{card.label}</span>
                {card.href ? (
                  <a href={card.href} class="contact__card-value">{card.value}</a>
                ) : (
                  <p class="contact__card-value">{card.value}</p>
                )}
              </div>
            </div>
          ))}
        </div>

        <!-- Social links -->
        <div class="contact__socials">
          {socialLinks.map((link) => (
            <a href={link.url} target="_blank" rel="noopener noreferrer" class="contact__social glass-card" aria-label={link.name}>
              <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <Fragment set:html={icons[link.icon] || ''} />
              </svg>
            </a>
          ))}
        </div>
      </div>

      <!-- Form column -->
      <form class="contact__form glass-card reveal" action={formAction} method="POST">
        <input type="hidden" name="_captcha" value="false" />
        <input type="hidden" name="_template" value="table" />

        <div class="contact__field">
          <label for="name" class="contact__label">Nom</label>
          <input type="text" name="name" id="name" required class="contact__input" placeholder="Votre nom" />
        </div>

        <div class="contact__field">
          <label for="email" class="contact__label">Email</label>
          <input type="email" name="email" id="email" required class="contact__input" placeholder="votre@email.com" />
        </div>

        <div class="contact__field">
          <label for="subject" class="contact__label">Sujet</label>
          <input type="text" name="_subject" id="subject" required class="contact__input" placeholder="Sujet du message" />
        </div>

        <div class="contact__field">
          <label for="message" class="contact__label">Message</label>
          <textarea name="message" id="message" required rows="5" class="contact__input contact__textarea" placeholder="Votre message..."></textarea>
        </div>

        <button type="submit" class="contact__submit">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <Fragment set:html={icons.send} />
          </svg>
          Envoyer
        </button>
      </form>
    </div>
  </div>
</section>

<style>
  .contact__grid {
    display: grid;
    grid-template-columns: 1fr 1.2fr;
    gap: 2rem;
    max-width: 900px;
    margin: 0 auto;
    align-items: start;
  }

  /* Info column */
  .contact__cards {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }

  .contact__card {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1.25rem;
  }

  .contact__card-icon {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(99, 102, 241, 0.08);
    border: 1px solid rgba(99, 102, 241, 0.15);
    border-radius: var(--radius-md);
    flex-shrink: 0;
    transition: all var(--transition-base);
  }

  .contact__card-icon svg {
    width: 22px;
    height: 22px;
    color: var(--color-primary-light);
  }

  .contact__card:hover .contact__card-icon {
    transform: scale(1.1);
    background: rgba(99, 102, 241, 0.15);
    box-shadow: 0 0 16px rgba(99, 102, 241, 0.2);
  }

  .contact__card-label {
    display: block;
    font-size: 0.75rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--color-text-muted);
    margin-bottom: 0.15rem;
  }

  .contact__card-value {
    font-size: 0.9rem;
    font-weight: 500;
    color: #fff;
    text-decoration: none;
  }

  a.contact__card-value:hover {
    color: var(--color-primary-light);
  }

  /* Social links */
  .contact__socials {
    display: flex;
    gap: 0.75rem;
  }

  .contact__social {
    width: 48px;
    height: 48px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    text-decoration: none;
  }

  .contact__social svg {
    width: 20px;
    height: 20px;
    color: var(--color-text-muted);
    transition: color var(--transition-fast);
  }

  .contact__social:hover svg {
    color: var(--color-primary-light);
  }

  /* Form */
  .contact__form {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact__field {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .contact__label {
    font-size: 0.72rem;
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-muted);
    font-weight: 600;
  }

  .contact__input {
    padding: 0.75rem 1rem;
    background: rgba(10, 15, 30, 0.6);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    font-family: var(--font-sans);
    font-size: 0.9rem;
    color: var(--color-text);
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    outline: none;
    width: 100%;
  }

  .contact__input::placeholder {
    color: rgba(148, 163, 184, 0.5);
  }

  .contact__input:focus {
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(99, 102, 241, 0.1);
  }

  .contact__textarea {
    resize: vertical;
    min-height: 120px;
  }

  .contact__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.85rem 2rem;
    background: var(--gradient-primary);
    color: #fff;
    border: none;
    border-radius: var(--radius-full);
    font-family: var(--font-sans);
    font-size: 0.95rem;
    font-weight: 600;
    cursor: pointer;
    transition: all var(--transition-base);
    box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
  }

  .contact__submit svg {
    width: 18px;
    height: 18px;
  }

  .contact__submit:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 25px rgba(99, 102, 241, 0.4);
  }

  @media (max-width: 768px) {
    .contact__grid {
      grid-template-columns: 1fr;
    }

    .contact__form {
      padding: 1.5rem;
    }
  }
</style>
